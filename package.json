{
  "name": "jihao-copy-image-text",
  "version": "1.1.15",
  "description": "复制图文增强版 (Copy Image Text Plus) - Copy Obsidian note content, including local images, as rich text, Markdown, or HTML.",
  "main": "main.js",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "build": "npm run typecheck && vite build && tsx scripts/copy-build-output.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "version:bump": "tsx scripts/bump-version.ts",
    "install:local": "tsx scripts/install-local.ts",
    "release:github": "tsx scripts/release-github.ts"
  },
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=25.9.0 <26"
  },
  "keywords": [],
  "author": "jihaohaaaa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jihaohaaaa/obsidian-copy-image-text.git"
  },
  "bugs": {
    "url": "https://github.com/jihaohaaaa/obsidian-copy-image-text/issues"
  },
  "homepage": "https://github.com/jihaohaaaa/obsidian-copy-image-text#readme",
  "license": "MIT",
  "devDependencies": {
    "@electron/remote": "^2.1.3",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "obsidian": "1.12.3",
    "prettier": "^3.8.3",
    "tslib": "2.8.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "tslib": "^2.8.1"
  }
}
